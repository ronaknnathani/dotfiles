{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "teal": "#94E2D5",
    "pink": "#F5C2E7",
    "lavender": "#B4BEFE",
    "green": "#A6E3A1",
    "peach": "#FAB387",
    "red": "#F38BA8",
    "yellow": "#F9E2AF",
    "muted": "#6C7086"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:teal",
          "style": "plain",
          "template": "\udb84\udcfe ({{ .Context }}:<p:lavender>{{ .Namespace }}</>) ",
          "type": "kubectl"
        },
        {
          "foreground": "p:pink",
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path",
          "options": {
            "home_icon": "~",
            "style": "agnoster_short",
            "max_depth": 3
          }
        },
        {
          "foreground": "p:lavender",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}"
          ],
          "style": "plain",
          "template": "\ue725 {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }} \u2717{{ end }} ",
          "type": "git",
          "options": {
            "branch_icon": "",
            "fetch_status": true
          }
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "style": "plain",
          "template": "\u276f",
          "type": "status",
          "options": {
            "always_enabled": true
          }
        }
      ],
      "type": "prompt",
      "newline": true
    }
  ],
  "final_space": true,
  "secondary_prompt": {
    "foreground": "p:muted",
    "template": "\u276f\u276f "
  },
  "version": 4
}
