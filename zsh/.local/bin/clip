#!/usr/bin/env bash
# Portable clipboard copy: reads stdin, writes to the system clipboard.
# Falls back to OSC52 escape for SSH sessions so the host terminal copies it.
set -e
if [[ "$OSTYPE" == darwin* ]] && command -v pbcopy &>/dev/null; then
  pbcopy
elif command -v xclip &>/dev/null; then
  xclip -selection clipboard
elif command -v wl-copy &>/dev/null; then
  wl-copy
else
  printf '\033]52;c;%s\007' "$(base64 | tr -d '\n')"
fi
